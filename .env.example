# Supabase – from Dashboard → Project Settings → API
# Project URL (use your project ref, e.g. https://bueemmgkyuihkffxuaaj.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://bueemmgkyuihkffxuaaj.supabase.co
# Anon/public key (under "Project API keys")
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Direct Postgres URL (optional; for migrations or server-only DB access)
# Replace [YOUR-PASSWORD] with your database password
# DATABASE_URL=postgresql://postgres.bueemmgkyuihkffxuaaj:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# REQUIRED for admin uploads/edits when using table login (EstherWilliam@gmail.com). Stops "row-level security policy" errors.
# From Dashboard → Project Settings → API → "service_role" (secret) — copy the key, never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: secret for signing admin session cookie (table login). If unset, anon key is used.
# ADMIN_SESSION_SECRET=your-random-secret

# Optional: set to "true" to skip admin login (development only)
# NEXT_PUBLIC_ADMIN_AUTH_DISABLED=true
DATABASE_URL=postgresql://postgres.bueemmgkyuihkffxuaaj:Willy1@gmail.com@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
